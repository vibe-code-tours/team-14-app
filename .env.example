# =============================================================================
# WorkerVoice - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Never commit .env to version control

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=migrant_user
POSTGRES_PASSWORD=YOUR_DATABASE_PASSWORD
POSTGRES_DB=migrant_review_db

# PostgreSQL connection string (used by Prisma)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://migrant_user:YOUR_DATABASE_PASSWORD@localhost:5432/migrant_review_db

# =============================================================================
# Application URLs
# =============================================================================
# Base URL for the API (used by bot and frontend)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public site URL for Telegram bot buttons and deep links
# IMPORTANT: Must be HTTPS for Telegram URL buttons to work
# For local development, use ngrok: https://your-ngrok-url.ngrok-free.dev
# For production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Admin Configuration
# =============================================================================
# Admin API key for protected routes
ADMIN_KEY=your-admin-key

# =============================================================================
# Authentication (Auth.js / NextAuth)
# =============================================================================
# Generate secret with: npx auth-secret
AUTH_SECRET=generate-with-npx-auth-secret

# Auth callback URL
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
AUTH_URL=http://localhost:3000

# =============================================================================
# Email Service (Resend)
# =============================================================================
# Used for verification emails and password reset
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Sender email address (must be from verified domain)
EMAIL_FROM=noreply@workervoice.example

# =============================================================================
# Telegram Bot Configuration
# =============================================================================
# Bot token from @BotFather on Telegram
# How to get:
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot
# 3. Follow instructions to create bot
# 4. Copy the token (format: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Webhook verification secret
# Generate with: openssl rand -hex 32
# Used to verify requests actually come from Telegram
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Development Tips
# =============================================================================
#
# 1. Local Development with Telegram:
#    - Start ngrok: ngrok http 3000
#    - Update NEXT_PUBLIC_SITE_URL with ngrok HTTPS URL
#    - Set webhook to ngrok URL
#
# 2. Production Deployment:
#    - Update NEXT_PUBLIC_SITE_URL with Vercel URL
#    - Update NEXT_PUBLIC_API_URL with Vercel URL
#    - Set webhook to Vercel URL
#
# 3. Generate secrets:
#    - AUTH_SECRET: npx auth-secret
#    - TELEGRAM_WEBHOOK_SECRET: openssl rand -hex 32
#
# 4. Never commit .env to version control
#    - .env is in .gitignore
#    - Only commit .env.example

# ── Docker PostgreSQL ──
# Used by docker-compose.yml and local development
POSTGRES_USER=workervoice
POSTGRES_PASSWORD=workervoice_dev_pw
POSTGRES_DB=migrant_review

# Local dev: connect to Docker PostgreSQL (host port 5433 → container 5432)
DATABASE_URL=postgresql://workervoice:workervoice_dev_pw@localhost:5433/migrant_review

# ── Auth.js (NextAuth) ──
# Generate a secret: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# ── Email (Resend) — optional, used for verification + password reset ──
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@workervoice.dev

{
  "name": "migrant-review-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:seed": "tsx prisma/seed-e2e.ts",
    "db:seed": "prisma db execute --file prisma/seed/factories_bangkok.sql",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "1.61.1",
    "@prisma/config": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "7.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "xlsx": "^0.18.5"
  }
}

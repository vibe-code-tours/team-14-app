// Migrant Review Platform - Database Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum OrganizationType {
  factory
  agency
}

enum SuggestionStatus {
  pending
  approved
  rejected
}

enum FactoryStatus {
  pending
  approved
  declined
}

enum UserRole {
  user
  moderator
  administrator
}

enum UserStatus {
  active
  blocked
}

// Registered platform users (auth)
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  // Real name, captured for admin audit trails only — never exposed via any public API.
  fullName      String    @map("full_name") @db.VarChar(255)
  // Optional privacy upgrade: shown instead of fullName wherever a name is displayed publicly.
  // If null, fullName is shown by default — this is an intentional product decision, not a bug.
  nickname      String?   @map("nickname") @db.VarChar(50)
  role          UserRole  @default(user)
  isAdmin       Boolean   @default(false) @map("is_admin")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  status        UserStatus @default(active)
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  factories           Factory[]
  reviews             Review[]

  @@map("users")
}

// Auth.js adapter-standard model (required field shapes per @auth/prisma-adapter contract)
model Account {
  id                String  @id @default(cuid())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Auth.js adapter-standard model (JWT session strategy does not require this table,
// but it's kept so the adapter's type contract is satisfied and OAuth/email providers
// can be added later without another migration)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Auth.js adapter-standard model, reused here for the email-verification flow
// (identifier = email). token is stored as a SHA-256 hash, never the raw value.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Password reset tokens have their own model (distinct lifecycle from VerificationToken:
// per-user, 1-hour expiry). token is stored as a SHA-256 hash, never the raw value.
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(255)
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Fixed-window rate limit counters (register, password reset, login attempts).
// DB-backed rather than in-memory so limits hold correctly across multiple app instances.
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @map("window_start")

  @@map("rate_limits")
}

// User-submitted organizations (pending admin approval)
model SuggestedOrganization {
  id        Int              @id @default(autoincrement())
  name      String           @db.VarChar(255)
  type      OrganizationType
  country   String           @db.VarChar(255)
  city      String?          @db.VarChar(255)
  status    SuggestionStatus @default(pending)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @map("updated_at")

  reviews Review[]

  @@map("suggested_organizations")
}

// DIW factory data (auto-approved, imported from Excel)
model Factory {
  id               Int      @id @default(autoincrement())
  regNumber        String?  @unique @map("reg_number") @db.VarChar(50)
  name             String   @db.VarChar(500)
  operator         String?  @db.VarChar(500)
  businessActivity String?  @map("business_activity") @db.Text
  houseNumber      String?  @map("house_number") @db.VarChar(100)
  village          String?  @db.VarChar(100)
  soi              String?  @db.VarChar(200)
  road             String?  @db.VarChar(200)
  subdistrict      String?  @db.VarChar(200)
  district         String?  @db.VarChar(200)
  province         String?  @db.VarChar(200)
  postalCode       String?  @map("postal_code") @db.VarChar(10)
  phone            String?  @db.VarChar(50)
  type             String?  @db.VarChar(100)
  capitalBaht      Decimal? @map("capital_baht") @db.Decimal
  workers          Int?
  horsepower       Decimal? @db.Decimal
  tsic             String?  @db.VarChar(50)
  oldRegNumber     String?  @map("old_reg_number") @db.VarChar(50)
  country          String   @default("Thailand") @db.VarChar(100)
  status           FactoryStatus @default(approved)
  image            String?
  userId           Int?      @map("user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  reviews Review[]

  @@index([name])
  @@index([province])
  @@index([district])
  @@map("factories")
}

// Reviews (linked to either user-submitted org OR DIW factory)
model Review {
  id             Int      @id @default(autoincrement())
  organizationId Int?     @map("organization_id")
  factoryId      Int?     @map("factory_id")
  workerRole     String   @map("worker_role") @db.VarChar(255)
  countryFrom    String   @map("country_from") @db.VarChar(100)
  ratingSalary   Int      @map("rating_salary")
  ratingOt       Int      @map("rating_ot")
  ratingHousing  Int      @map("rating_housing")
  reviewText     String   @map("review_text") @db.Text
  isVisible      Boolean  @default(true)
  userId         Int?     @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization SuggestedOrganization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  factory      Factory?              @relation(fields: [factoryId], references: [id], onDelete: Cascade)

  @@index([factoryId])
  @@index([organizationId])
  @@map("reviews")
}
